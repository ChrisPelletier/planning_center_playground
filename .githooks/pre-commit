#!/usr/bin/env bash
set -euo pipefail

# Run mix format and abort the commit if it modified any files.
# This ensures the code is formatted before commits.

# Ensure we run from the repo root
cd "$(git rev-parse --show-toplevel)"

mix format

if ! git diff --quiet --exit-code; then
  echo "mix format changed files. Please stage the changes and re-run commit."
  echo "You can add them with: git add -A"
  exit 1
fi

exit 0
